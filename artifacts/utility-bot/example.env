# ─── Required ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
OWNER_IDS=your_discord_user_id_here

# ─── Lavalink (Required for music) ───────────────────────────────────────────
# FIX: These were previously hardcoded in config.js — now required env vars.
# Run your own Lavalink server: https://github.com/lavalink-devs/Lavalink
LAVALINK_HOST=your.lavalink.host.here
LAVALINK_PORT=2333
LAVALINK_PASSWORD=your_lavalink_password_here
LAVALINK_SECURE=false
LAVALINK_ID=main-node

# ─── Sharding ─────────────────────────────────────────────────────────────────
# FIX: Shard count is now configurable (was hardcoded to 4).
# Use 'auto' to let Discord determine the optimal number.
TOTAL_SHARDS=auto
SHARDS_PER_CLUSTER=2

# ─── Bot Settings ─────────────────────────────────────────────────────────────
PREFIX=.
SUPPORT_SERVER_URL=https://discord.gg/your_invite_here
STATUS_TEXT=.help | AeroX
STATUS_TYPE=dnd
NODE_ENV=production
DEBUG=false

# ─── Spotify (Optional — for recommendations & search) ───────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Last.fm (Optional — for lyrics & metadata) ───────────────────────────────
LASTFM_API_KEY=

# ─── Assets (Optional — fallback images) ─────────────────────────────────────
DEFAULT_TRACK_ARTWORK=
DEFAULT_THUMBNAIL=
HELP_THUMBNAIL=
BANNER_URL=

# ─── Webhook Logging (Optional) ───────────────────────────────────────────────
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_USERNAME=Bot Logger
WEBHOOK_AVATAR_URL=
WEBHOOK_INFO_ENABLED=true
WEBHOOK_SUCCESS_ENABLED=true
WEBHOOK_WARNING_ENABLED=true
WEBHOOK_ERROR_ENABLED=true
WEBHOOK_DEBUG_ENABLED=false
