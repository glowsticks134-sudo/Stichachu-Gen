# ─────────────────────────────────────────────────────────────────────────────
# Memberk Emails Bot — Environment Variables
#
# On Railway: paste each key/value into the "Variables" tab of your service.
# On Replit:  use the Secrets panel (lock icon in the sidebar).
# Locally:    copy this file to .env and fill in your values.
#
# NEVER commit a .env file with real values to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord (required) ────────────────────────────────────────────────────────
# Bot token from: discord.com/developers → your app → Bot → Reset Token
DISCORD_BOT_TOKEN=your-bot-token-here

# Application client ID from: discord.com/developers → General Information
DISCORD_CLIENT_ID=your-client-id-here

# Set during development for INSTANT command registration in one server.
# Leave blank (or remove) for global deployment — takes up to 1 hour to propagate.
# On Railway production: leave this BLANK so commands register globally.
DISCORD_GUILD_ID=

# ── Domains (required) ────────────────────────────────────────────────────────
# Comma-separated prefix:domain pairs. Each becomes a slash command.
# /gen picks a random domain from this list.
# Example: lgen:larpers.cc creates /lgen that generates @larpers.cc aliases.
DOMAIN_COMMANDS=lgen:larpers.cc,ngen:nachtmail.online,dgen:dxdmail.cc,vgen:vinmail.org,1gen:nachthub.com,zgen:zacmail.site,mgen:madmail.online,cgen:cuckmail.online,sgen:sonmail.online

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Max active aliases per user. Warning shown at 80% capacity. (default: 10)
MAX_ALIASES_PER_USER=10

# ── Slash Command Auto-Registration ──────────────────────────────────────────
# Set to "true" for ONE deploy to register slash commands automatically at startup.
# After commands appear in Discord, set back to "false" — commands persist in
# Discord until you change DOMAIN_COMMANDS and redeploy with true again.
# Cost: adds ~1-2 seconds to startup time when true.
AUTO_DEPLOY_COMMANDS=false

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
#
# Railway persistent volumes:
#   1. In Railway dashboard → your service → "Volumes" tab
#   2. Add a volume, mount path: /data
#   3. Set DATABASE_PATH=/data/aliases.db
#
# Without a volume the database resets on every deploy (fine for testing).
# Default (no volume): a local data/ folder inside the project.
DATABASE_PATH=

# ── Log Channel (optional) ────────────────────────────────────────────────────
# Discord channel ID for admin audit logging (alias created/deleted events).
# How to get it: enable Developer Mode in Discord → right-click channel → Copy ID
LOG_CHANNEL_ID=

# ── Webhook Server — Email-to-DM Delivery (optional) ─────────────────────────
# Enable to receive inbound emails and deliver them to alias owners via DM.
#
# On Railway: set ENABLE_WEBHOOK_SERVER=true and the bot will listen on the
# PORT Railway automatically assigns. No need to set WEBHOOK_PORT.
#
# Webhook endpoints (POST):
#   /webhook/mailgun    — Mailgun inbound routing format
#   /webhook/cloudflare — Cloudflare Email Workers format
#   /webhook/email      — Generic JSON: { to, from, subject, text }
ENABLE_WEBHOOK_SERVER=false

# Railway injects PORT automatically — only set this for local development.
# WEBHOOK_PORT=3001

# Optional: require X-Webhook-Secret header on all webhook requests.
# Set the same value in your mail provider's webhook configuration.
WEBHOOK_SECRET=
