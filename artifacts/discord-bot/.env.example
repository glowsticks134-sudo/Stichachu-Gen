# ─────────────────────────────────────────────────────────────────────────────
# Discord Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Your application's client ID (found on the General Information page)
DISCORD_CLIENT_ID=your-client-id-here

# (Optional) Set this during development for instant command registration.
# Remove it (or leave blank) to deploy commands globally.
DISCORD_GUILD_ID=your-test-server-id-here

# ── Email Provider ────────────────────────────────────────────────────────────
# Which provider to use: simplelogin | cloudflare | local
#
#   simplelogin  — Full alias management via SimpleLogin API.
#                  Requires SIMPLELOGIN_API_KEY and EMAIL_DOMAIN.
#
#   cloudflare   — Creates individual routing rules via Cloudflare API.
#                  Requires CLOUDFLARE_API_TOKEN, CLOUDFLARE_ZONE_ID,
#                  EMAIL_DOMAIN, and CLOUDFLARE_DESTINATION_EMAIL.
#
#   local        — No external API. Generates alias names locally and
#                  stores them in SQLite only. Use this if you already
#                  have a catch-all forwarding rule set up externally.
EMAIL_PROVIDER=local

# The custom domain on which aliases are created (e.g. memberk.xyz)
EMAIL_DOMAIN=yourdomain.com

# ── SimpleLogin (only needed when EMAIL_PROVIDER=simplelogin) ────────────────
# Generate your API key at: https://app.simplelogin.io/dashboard/api_key
SIMPLELOGIN_API_KEY=

# ── Cloudflare Email Routing (only needed when EMAIL_PROVIDER=cloudflare) ────
# Create an API token at https://dash.cloudflare.com/profile/api-tokens
# Required permission: "Email Routing Rules: Edit" for your zone.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# The real inbox that Cloudflare will forward alias emails to
CLOUDFLARE_DESTINATION_EMAIL=you@gmail.com

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Maximum number of active aliases a single Discord user may own (default: 5)
MAX_ALIASES_PER_USER=5
