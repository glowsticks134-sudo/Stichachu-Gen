# ─────────────────────────────────────────────────────────────────────────────
# Memberk Emails Bot — Environment Variables
#
# Railway: paste each key/value into the "Variables" tab of your service.
# Replit:  use the Secrets panel (lock icon).
# Local:   copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord (required) ────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here

# For instant command registration in one server (dev only).
# Leave blank for global deployment (takes up to 1 hour).
DISCORD_GUILD_ID=

# ── Domains (required) ────────────────────────────────────────────────────────
DOMAIN_COMMANDS=lgen:larpers.cc,ngen:nachtmail.online,dgen:dxdmail.cc,vgen:vinmail.org,1gen:nachthub.com,zgen:zacmail.site,mgen:madmail.online,cgen:cuckmail.online,sgen:sonmail.online

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Max active aliases per user (default: 20, warning shown at 80%)
MAX_ALIASES_PER_USER=20

# ── Slash Command Auto-Registration ──────────────────────────────────────────
# Set to "true" for ONE deploy to register slash commands at startup.
# Set back to "false" after — commands stay in Discord until explicitly changed.
AUTO_DEPLOY_COMMANDS=false

# ── Database ──────────────────────────────────────────────────────────────────
# Railway volume: add volume at /data, then set DATABASE_PATH=/data/aliases.db
DATABASE_PATH=

# ── Log Channel (optional) ────────────────────────────────────────────────────
# Discord channel ID — bot posts here when aliases are created/deleted.
LOG_CHANNEL_ID=

# ── Webhook Server — Email-to-DM Delivery (optional) ─────────────────────────
ENABLE_WEBHOOK_SERVER=false
# Railway injects PORT automatically — only set WEBHOOK_PORT for local dev.
# WEBHOOK_PORT=3001
WEBHOOK_SECRET=
