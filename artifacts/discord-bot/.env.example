# ─────────────────────────────────────────────────────────────────────────────
# Memberk Emails Bot — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here

# Guild ID for instant command registration during development.
# Remove (or leave blank) to deploy commands globally (up to 1 hour delay).
DISCORD_GUILD_ID=your-test-server-id

# ── Domains ───────────────────────────────────────────────────────────────────
# Each entry creates a slash command /prefix that generates @domain aliases.
# /gen picks a random domain from this list.
DOMAIN_COMMANDS=lgen:larpers.cc,ngen:nachtmail.online,dgen:dxdmail.cc,vgen:vinmail.org,1gen:nachthub.com,zgen:zacmail.site,mgen:madmail.online,cgen:cuckmail.online,sgen:sonmail.online

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Max active aliases per user. Warning shown at 80% capacity. (default: 10)
MAX_ALIASES_PER_USER=10

# ── Log Channel ───────────────────────────────────────────────────────────────
# Optional: Discord channel ID for admin audit logging.
# Right-click a channel → "Copy Channel ID" (enable Developer Mode first).
# When set, the bot posts an embed here every time an alias is created or deleted.
# LOG_CHANNEL_ID=your-channel-id-here

# ── Webhook Server (Email-to-DM delivery) ─────────────────────────────────────
# Set to "true" to enable the HTTP webhook server that forwards inbound emails
# to alias owners via Discord DM. Requires your mail provider to POST to:
#   POST /webhook/mailgun   — Mailgun inbound routing
#   POST /webhook/cloudflare — Cloudflare Email Workers
#   POST /webhook/email     — Generic JSON: { to, from, subject, text }
ENABLE_WEBHOOK_SERVER=false
WEBHOOK_PORT=3001

# Optional: require X-Webhook-Secret header on all webhook POST requests.
# WEBHOOK_SECRET=your-random-secret-here
