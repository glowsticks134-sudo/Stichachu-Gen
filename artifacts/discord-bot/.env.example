# ─────────────────────────────────────────────────────────────────────────────
# Memberk Emails Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here

# Set this for INSTANT command registration during development.
# Remove (or leave blank) to deploy commands globally (takes up to 1 hour).
DISCORD_GUILD_ID=your-test-server-id

# ── Domains ───────────────────────────────────────────────────────────────────
# Comma-separated list of prefix:domain pairs.
# Each pair creates a slash command /prefix that generates an alias @domain.
#
# Example shown matches the bot in the screenshot:
DOMAIN_COMMANDS=lgen:larpers.cc,ngen:nachtmail.online,dgen:dxdmail.cc,vgen:vinmail.org,1gen:nachthub.com,zgen:zacmail.site,mgen:madmail.online,cgen:cuckmail.online,sgen:sonmail.online

# /gen picks a random domain from this list. Defaults to domains in DOMAIN_COMMANDS.
# Set this if you want a different set of domains for random selection.
# DOMAINS=larpers.cc,nachtmail.online,dxdmail.cc

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Maximum number of active aliases any single Discord user may hold (default: 10)
MAX_ALIASES_PER_USER=10

# ── Webhook Server (Email-to-DM delivery) ─────────────────────────────────────
# Set to "true" to enable the HTTP webhook server that forwards incoming emails
# to users via Discord DM.
ENABLE_WEBHOOK_SERVER=false

# Port the webhook server listens on (default: 3001)
WEBHOOK_PORT=3001

# Optional secret for webhook request authentication.
# Set this in your mail provider's webhook config and here.
# Requests without this in the X-Webhook-Secret header will be rejected.
# WEBHOOK_SECRET=your-random-secret-here

# ── Mail Provider Setup (choose one) ─────────────────────────────────────────
# For email-to-DM delivery, you need a mail provider that can receive emails
# for your domains and POST them to your webhook server.
#
# Option A: Mailgun (https://mailgun.com)
#   1. Add your domain to Mailgun
#   2. Configure an Inbound Route: match all → store & notify → POST to:
#      https://your-bot-domain.replit.app/webhook/mailgun
#   3. Set WEBHOOK_SECRET to match your route's signing key
#
# Option B: Cloudflare Email Workers
#   1. Enable Email Routing for your zone
#   2. Create an Email Worker that POSTs to:
#      https://your-bot-domain.replit.app/webhook/cloudflare
#   Worker format: { to, from, subject, text }
#
# Option C: Any provider supporting generic webhooks
#   POST to: https://your-bot-domain.replit.app/webhook/email
#   JSON body: { "to": "alias@domain.com", "from": "...", "subject": "...", "text": "..." }
#
# Catch-all setup (required for all options):
#   Your domains need a catch-all forwarding rule so ALL addresses receive email.
#   This is usually done with a wildcard (*@yourdomain.com) routing rule.
