# ─────────────────────────────────────────────────────────────────────────────
# Memberk Emails Bot — Environment Variables
#
# MULTI-BOT SETUP:
#   Use numbered variables (_1, _2, _3, ...) to run multiple bots in parallel.
#   All bots share the same commands and database.
#   The first bot handles webhook DM delivery and log channel posting.
#
# SINGLE-BOT SETUP (legacy):
#   If no _1/_2 variables are set, falls back to DISCORD_BOT_TOKEN and
#   DISCORD_CLIENT_ID for backward compatibility.
#
# Railway: add these in the "Variables" tab of your service.
# Replit:  use the Secrets panel (lock icon).
# Local:   copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Bot 1 ─────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN_1=token-for-bot-1-here
DISCORD_CLIENT_ID_1=client-id-for-bot-1-here
# Optional: instant command registration for bot 1 in a specific guild (dev only)
DISCORD_GUILD_ID_1=

# ── Bot 2 ─────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN_2=token-for-bot-2-here
DISCORD_CLIENT_ID_2=client-id-for-bot-2-here
DISCORD_GUILD_ID_2=

# ── Bot 3, 4, 5 ... (add as many as you need, same pattern) ──────────────────
# DISCORD_BOT_TOKEN_3=
# DISCORD_CLIENT_ID_3=
# DISCORD_GUILD_ID_3=

# ── Global fallback (single-bot legacy, ignored if _1/_2 vars are set) ────────
# DISCORD_BOT_TOKEN=
# DISCORD_CLIENT_ID=
# DISCORD_GUILD_ID=

# ── Domains (shared across ALL bots) ─────────────────────────────────────────
DOMAIN_COMMANDS=lgen:larpers.cc,ngen:nachtmail.online,dgen:dxdmail.cc,vgen:vinmail.org,1gen:nachthub.com,zgen:zacmail.site,mgen:madmail.online,cgen:cuckmail.online,sgen:sonmail.online

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
MAX_ALIASES_PER_USER=20

# ── Slash Command Auto-Registration ──────────────────────────────────────────
# Set to "true" for ONE deploy to register commands for all bots automatically.
# Set back to "false" after — commands stay until explicitly changed.
AUTO_DEPLOY_COMMANDS=false

# ── Database (shared across all bots) ─────────────────────────────────────────
# Railway volume: mount at /data, set DATABASE_PATH=/data/aliases.db
DATABASE_PATH=

# ── Log Channel (uses first bot's client to post) ─────────────────────────────
LOG_CHANNEL_ID=

# ── Webhook Server (uses first bot's client for DM delivery) ─────────────────
ENABLE_WEBHOOK_SERVER=false
# WEBHOOK_PORT=3001
WEBHOOK_SECRET=
